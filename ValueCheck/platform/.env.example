# Equity research platform — example environment.
# Copy to `.env` and adjust. All variables are prefixed EQUITY_.
# No secrets are committed; fill real values locally only.

# -- app --------------------------------------------------------------------
EQUITY_APP_NAME=equity-research-platform
EQUITY_ENVIRONMENT=local
EQUITY_DEBUG=false

# -- logging ----------------------------------------------------------------
EQUITY_LOG_LEVEL=INFO
# true => JSON logs (prod/CI); false => human-readable console logs (dev)
EQUITY_LOG_JSON=false

# -- persistence ------------------------------------------------------------
EQUITY_DATABASE_PATH=equity.db

# -- SEC EDGAR --------------------------------------------------------------
# SEC fair-access REQUIRES an identifying User-Agent. Set your real name+email.
# Leave unset for offline/mock-only work; the Edgar adapter (Phase 2) needs it.
# EQUITY_EDGAR_IDENTITY=Jane Doe jane@example.com
EQUITY_EDGAR_RATE_LIMIT_PER_SEC=5.0

# -- market data ------------------------------------------------------------
EQUITY_REQUEST_TIMEOUT_SECONDS=15.0
