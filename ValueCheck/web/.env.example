# ValueCheck web — example environment. Copy to .env.local to override.

# Base path the browser uses for API calls. Default "/api" goes through the
# Vite dev proxy (see vite.config.ts), which forwards to the backend.
VITE_API_BASE=/api

# Where the dev proxy forwards to (dev server only, not shipped to the client).
VITE_BACKEND_URL=http://127.0.0.1:8000
